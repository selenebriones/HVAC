	</style>

	<!-- GSAP Page Specific Scripts -->
	<script is:inline>
		document.addEventListener('DOMContentLoaded', () => {
			// Hero Section Animations
			const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

			// Initial state setup for Hero
			gsap.set('.hero-img', { scale: 1.15 });
			gsap.set('.hero-tag', { y: 20, opacity: 0 });
			gsap.set('.hero-title', { y: 40, opacity: 0 });
			gsap.set('.hero-desc', { y: 30, opacity: 0 });
			gsap.set('.hero-cta', { y: 30, opacity: 0 });

			// Animate Hero in sequence
			tl.to('.hero-img', { scale: 1, duration: 2.5, ease: 'power2.out' })
			  .to('.hero-tag', { y: 0, opacity: 1, duration: 0.8 }, '-=1.8')
			  .to('.hero-title', { y: 0, opacity: 1, duration: 1 }, '-=1.6')
			  .to('.hero-desc', { y: 0, opacity: 1, duration: 0.8 }, '-=1.2')
			  .to('.hero-cta', { y: 0, opacity: 1, duration: 0.8 }, '-=0.9');

			// Soluciones Especializadas Animation
			gsap.utils.toArray('.sol-card').forEach((card, i) => {
				ScrollTrigger.create({
					trigger: card,
					start: 'top 85%',
					animation: gsap.fromTo(card, 
						{ y: 50, opacity: 0 }, 
						{ y: 0, opacity: 1, duration: 0.8, ease: 'power2.out', delay: i * 0.2 }
					)
				});
			});

			// Equipamiento Animation (Stagger ascendente)
			gsap.utils.toArray('.equip-card').forEach((card, i) => {
				ScrollTrigger.create({
					trigger: card,
					start: 'top 85%',
					animation: gsap.fromTo(card, 
						{ y: 50, opacity: 0 }, 
						{ y: 0, opacity: 1, duration: 0.6, ease: 'power2.out', delay: (i % 4) * 0.15 }
					)
				});
			});

			// Servicios Animation (Desplazamiento lateral y opacidad)
			gsap.utils.toArray('.serv-card').forEach((card, i) => {
				ScrollTrigger.create({
					trigger: card,
					start: 'top 85%',
					animation: gsap.fromTo(card, 
						{ x: i === 0 ? -50 : 50, opacity: 0 }, 
						{ x: 0, opacity: 1, duration: 0.8, ease: 'power2.out', delay: i === 0 ? 0 : i * 0.15 }
					)
				});
			});

			// Form Container Animation
			ScrollTrigger.create({
				trigger: '.form-container',
				start: 'top 80%',
				animation: gsap.fromTo('.form-container', 
					{ y: 60, opacity: 0, scale: 0.98 }, 
					{ y: 0, opacity: 1, scale: 1, duration: 1, ease: 'power3.out' }
				)
			});
		});
	</script>
